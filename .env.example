# ============================================================================
# SaaS Dashboard Template - Environment Configuration
# ============================================================================
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials below
# 3. NEVER commit .env to git (already in .gitignore)
#
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Required)
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
#
# 1. Go to your Supabase project
# 2. Click Settings → API
# 3. Copy "Project URL" and "anon/public" key

SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Example:
# SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ----------------------------------------------------------------------------
# ANTHROPIC CLAUDE API (Required for AI Insights)
# ----------------------------------------------------------------------------
# Get your API key from: https://console.anthropic.com/
#
# 1. Create an account at console.anthropic.com
# 2. Go to API Keys
# 3. Create a new key
#
# Note: AI features will be disabled if this is not set

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Example:
# ANTHROPIC_API_KEY=sk-ant-api03-...


# ----------------------------------------------------------------------------
# OPTIONAL: CUSTOMIZATION
# ----------------------------------------------------------------------------

# App Branding (optional - defaults shown)
# APP_NAME=SaaS Dashboard
# APP_ICON=📊

# Features (optional - set to 'false' to disable)
# ENABLE_AI_INSIGHTS=true
# ENABLE_SIGNUP=true


# ----------------------------------------------------------------------------
# OPTIONAL: ADDITIONAL INTEGRATIONS
# ----------------------------------------------------------------------------

# Stripe (for payment tracking)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# SendGrid (for email reports)
# SENDGRID_API_KEY=SG...

# Slack (for notifications)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Google Analytics
# GA_TRACKING_ID=G-...


# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# ⚠️ IMPORTANT:
# - Never share your .env file
# - Never commit .env to version control
# - Rotate keys if accidentally exposed
# - Use different keys for dev/staging/production
#
# For production deployment:
# - Use platform environment variables (Streamlit Cloud, Heroku, etc.)
# - Enable Row Level Security in Supabase
# - Set up proper authentication flows
#
# ============================================================================
